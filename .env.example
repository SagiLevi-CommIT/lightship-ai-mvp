# AWS Configuration
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=       # Only for CI/CD; prefer SSO/IAM role
# AWS_SECRET_ACCESS_KEY=   # Only for CI/CD; prefer SSO/IAM role

# Bedrock LLM
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
TEMPERATURE=0.1
MAX_TOKENS=15000
TOP_P=1.0
TOP_K=250

# Rekognition
REKOGNITION_MIN_CONFIDENCE=60.0
REKOGNITION_MAX_LABELS=50

# S3 Buckets
PROCESSING_BUCKET=lightship-mvp-processing-ACCOUNTID
RESULTS_BUCKET=lightship-mvp-processing-ACCOUNTID
RESULTS_PREFIX=results

# DynamoDB
DYNAMODB_TABLE=lightship_jobs

# CORS (comma-separated origins, or * for dev)
CORS_ALLOWED_ORIGINS=*

# Frontend
BACKEND_API_URL=http://localhost:8000

# Logging
LOG_LEVEL=INFO
