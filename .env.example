# Lightship MVP — environment variables reference
#
# Copy to `.env` (repo root) and fill in the blanks for local development.
# Nothing in this file is deployed automatically; CloudFormation owns the
# real values in AWS. Refer to `infrastructure/backend-lambda-stack.yaml`
# for the authoritative Lambda env var set.

# --- AWS credentials (local + CI only; production uses an IAM role) --------
AWS_REGION=us-east-1
# SSO profile path is preferred — see .cursor/rules/010-aws-environment.mdc.
# If keys are required (CI without SSO), uncomment:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Backend: Bedrock / LLM ------------------------------------------------
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
TEMPERATURE=0.1
MAX_TOKENS=15000
TOP_P=1.0
TOP_K=250

# --- Backend: S3 + DynamoDB ------------------------------------------------
PROCESSING_BUCKET=lightship-mvp-processing-336090301206
DYNAMODB_TABLE=lightship_jobs

# --- Backend: pipeline tuning ----------------------------------------------
SNAPSHOT_STRATEGY=clustering       # naive | scene_change | clustering
ENABLE_FRAME_PREPROCESSING=true    # CLAHE + sharpen before CV detection
LOG_LEVEL=INFO
LOG_FORMAT=json                    # json (Lambda/CW) | text (local)

# --- Backend: Phase 3 dispatch path ----------------------------------------
# When `PROCESSING_QUEUE_URL` is set the API sends to SQS instead of Lambda
# self-invoke. `PIPELINE_STATE_MACHINE_ARN` is used by the dispatcher to
# start an execution per SQS message.
# Leave empty for local dev — /process-video falls back to a FastAPI
# background task that runs the pipeline in-process.
PROCESSING_QUEUE_URL=
PIPELINE_STATE_MACHINE_ARN=

# --- Backend: Phase 2 observability ----------------------------------------
EMIT_METRICS=true
METRICS_NAMESPACE=Lightship/Backend
ENVIRONMENT=mvp

# --- Frontend (ui-fe) ------------------------------------------------------
# When deployed behind the ALB, leave NEXT_PUBLIC_API_BASE empty so the
# browser makes same-origin requests and the ALB path rules do the routing.
# For local dev with the FastAPI uvicorn server, set it to the API host:
#   NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_API_BASE=

# --- Tests -----------------------------------------------------------------
# Optional S3 key pointing to a video already uploaded to PROCESSING_BUCKET;
# tests/test_e2e_live.py gates the pipeline E2E tests on this being set.
TEST_VIDEO_S3_KEY=

# Optional ALB DNS override — defaults to the production deployment.
# ALB_DNS=lightship-mvp-alb-xxxx.us-east-1.elb.amazonaws.com
